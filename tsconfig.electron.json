{
  /* =========================================================
  Nombre completo: tsconfig.electron.json
  Ruta o ubicación: /tsconfig.electron.json

  Función o funciones:
  - Compilar el proceso principal, preload y contratos compartidos.
  - Generar archivos separados del código de la interfaz.
  - Aplicar las reglas estrictas compartidas del proyecto.
  ========================================================= */
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "apps/desktop",
    "outDir": "dist-electron",
    "types": ["node", "electron"],
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false
  },
  "include": [
    "apps/desktop/main/**/*.ts",
    "apps/desktop/preload/**/*.cts",
    "apps/desktop/shared/**/*.ts"
  ]
}
