{
  "name": "editar-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Editor modular de video de escritorio preparado para automatización, efectos y crecimiento futuro.",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,ELECTRON -c auto \"vite --host 127.0.0.1\" \"npm run dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 npm run build:electron && electron .",
    "build": "npm run clean && npm run typecheck && npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:audio": "node --test tests/audio-analysis-domain.test.mjs tests/silence-detect-parser.test.mjs tests/audio-processing.test.mjs",
    "test:cache": "node --test tests/media-derivative-operations.test.mjs tests/media-cache-paths.test.mjs tests/media-derivatives.test.mjs",
    "test:database": "node --test tests/database.test.mjs",
    "test:effects": "node --test tests/clip-effects-domain.test.mjs tests/clip-properties.test.mjs",
    "test:engines": "node --test tests/ffmpeg-binary-service.test.mjs tests/ffprobe-parser.test.mjs tests/media-analysis.test.mjs",
    "test:ipc": "node --test tests/ipc-validation.test.mjs",
    "test:jobs": "node --test tests/job-queue.test.mjs",
    "test:media": "node --test tests/media-import.test.mjs",
    "test:navigation": "node --test tests/navigation.test.mjs",
    "test:projects": "node --test tests/project-management.test.mjs",
    "test:timeline": "node --test tests/timeline-domain.test.mjs tests/timeline-editing.test.mjs",
    "test:transitions": "node --test tests/transition-sound-domain.test.mjs tests/transition-sound-service.test.mjs",
    "clean": "node scripts/clean.mjs",
    "start": "npm run build && electron .",
    "verify": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22.16.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "typescript": "^7.0.2",
    "vite": "^7.0.0",
    "wait-on": "^8.0.4"
  },
  "editar": {
    "archivo": "package.json",
    "ruta": "/package.json",
    "funciones": [
      "Definir dependencias y metadatos del proyecto.",
      "Centralizar comandos de desarrollo, compilación, pruebas y ejecución.",
      "Establecer versiones mínimas de Node.js y npm."
    ]
  }
}
